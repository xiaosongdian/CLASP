# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# OpenAI API Configuration (for commercial persona generation)
# ============================================================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================================
# Test Mode API Configuration
# ============================================================================
TEST_API_BASE=https://api.openai.com/v1
TEST_API_KEY=your-test-api-key-here
TEST_API_MODEL=gpt-3.5-turbo

# ============================================================================
# Database Configuration (for SFT data generation)
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=user_actions_db
DB_USER=postgres
DB_PASSWORD=your-database-password-here

# ============================================================================
# File Paths
# ============================================================================
PROFILE_CACHE_FILE=./profile_cache.json

# ============================================================================
# Model Paths (optional, override defaults in config.py)
# ============================================================================
# ACTION_GENERATION_MODEL=path/to/your/action-model
# PROFILE_GENERATION_MODEL_RAW=path/to/your/profile-model
# SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-mpnet-base-v2
